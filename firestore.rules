rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getCommunityRole(communityId) {
      let path = /databases/$(database)/documents/communities/$(communityId);
      return exists(path) 
        ? get(path).data.get('roles', {}).get(request.auth.uid, null) 
        : null;
    }

    function isCommunityAdmin(communityId) {
      return isSignedIn() && getCommunityRole(communityId) == 'admin';
    }

    function isCommunityViewer(communityId) {
      return isSignedIn() && getCommunityRole(communityId) != null;
    }

    // --- Validation Helpers ---
    function isValidTransaction(data, isUpdate) {
      return data.amount is number && data.amount >= 0 &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 500 &&
             data.date is string &&
             data.userId == (isUpdate ? existing().userId : request.auth.uid) &&
             data.userName is string && data.userName.size() <= 200 &&
             (data.get('userTitle', null) == null || (data.userTitle is string && data.userTitle.size() <= 100)) &&
             (isUpdate ? data.createdAt == existing().createdAt : data.createdAt == request.time) &&
             (data.communityId == null || (data.communityId is string && data.communityId.size() <= 50));
    }

    // --- Collections ---
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        isOwner(existing().userId) ||
        (existing().communityId != null && isCommunityViewer(existing().communityId))
      );
      
      allow create: if isSignedIn() &&
                      isValidId(transactionId) &&
                      isValidTransaction(incoming(), false) &&
                      (
                        (incoming().communityId == null) ||
                        (incoming().communityId != null && isCommunityAdmin(incoming().communityId))
                      );

      allow update: if isSignedIn() &&
                      isValidTransaction(incoming(), true) &&
                      (
                        isOwner(existing().userId) ||
                        (existing().communityId != null && isCommunityAdmin(existing().communityId))
                      ) &&
                      incoming().userId == existing().userId &&
                      incoming().userName == existing().userName &&
                      incoming().get('userTitle', null) == existing().get('userTitle', null) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().communityId == existing().communityId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'description', 'date']);

      allow delete: if isSignedIn() && (
        isOwner(existing().userId) ||
        (existing().communityId != null && isCommunityAdmin(existing().communityId))
      );
    }

    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /communities/{communityId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.roles[request.auth.uid] != null;
      allow create: if isSignedIn() && isValidId(communityId) && 
                      incoming().name is string &&
                      incoming().roles is map &&
                      incoming().roles[request.auth.uid] == 'admin';
      allow update: if isSignedIn() && (
                      // 1. Admin can change anything
                      (resource.data.roles[request.auth.uid] == 'admin') ||
                      // 2. Non-member can join as viewer
                      (resource.data.roles[request.auth.uid] == null && 
                       incoming().roles[request.auth.uid] == 'viewer' &&
                       incoming().roles.size() == existing().roles.size() + 1 &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['roles']))
                    ) && 
                    incoming().roles.size() > 0 &&
                    incoming().roles.size() < 100;
      allow delete: if false;
    }
  }
}

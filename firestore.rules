rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getCommunityRole(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId)).data.roles[request.auth.uid];
    }

    function isCommunityAdmin(communityId) {
      return isSignedIn() && getCommunityRole(communityId) == 'admin';
    }

    function isCommunityViewer(communityId) {
      return isSignedIn() && getCommunityRole(communityId) != null;
    }

    // --- Validation Helpers ---
    function isValidTransaction(data) {
      return data.amount is number && data.amount >= 0 &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 500 &&
             data.date is string &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time &&
             (data.communityId == null || (data.communityId is string && data.communityId.size() <= 50));
    }

    // --- Collections ---
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        isOwner(existing().userId) ||
        (existing().communityId != null && isCommunityViewer(existing().communityId))
      );
      
      allow create: if isSignedIn() &&
                      isValidId(transactionId) &&
                      isValidTransaction(incoming()) &&
                      (
                        (incoming().communityId == null) ||
                        (incoming().communityId != null && isCommunityAdmin(incoming().communityId))
                      );

      allow update: if isSignedIn() &&
                      isValidTransaction(incoming()) &&
                      (
                        isOwner(existing().userId) ||
                        (existing().communityId != null && isCommunityAdmin(existing().communityId))
                      ) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().communityId == existing().communityId &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'type', 'category', 'description', 'date']);

      allow delete: if isSignedIn() && (
        isOwner(existing().userId) ||
        (existing().communityId != null && isCommunityAdmin(existing().communityId))
      );
    }

    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /communities/{communityId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && isCommunityViewer(communityId);
      allow create: if isSignedIn() && isValidId(communityId);
      allow update: if isCommunityAdmin(communityId) && 
                      incoming().roles.size() < 100;
      allow delete: if false;
    }
  }
}
